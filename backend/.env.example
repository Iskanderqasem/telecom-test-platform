# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=4000
NODE_ENV=development

# Get this from your Render PostgreSQL dashboard -> External Database URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# Set to true when connecting to Render's PostgreSQL from outside Render
DB_SSL=true

# Full path to adb.exe on your Windows laptop
ADB_PATH=C:\Users\YOUR_USERNAME\platform-tools\adb.exe

# Where to store test screenshots and logcat files
EVIDENCE_PATH=./storage/evidence

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING
